# pondex_ backend — required environment variables
# Copy this to .env for local dev, set on Railway for production

# Required — get from console.groq.com (free)
GROQ_API_KEY=your_groq_key_here

# Optional — get from newsapi.org (free tier)
NEWSAPI_KEY=

# Railway sets PORT automatically — do not set manually in production
# PORT=8000

# CORS — comma-separated list of allowed frontend origins
# Local dev: http://localhost:5173,http://localhost:5174
# Production: your GitHub Pages URL
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://dan123iel.github.io
